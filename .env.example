# Copy this file to .env or reuse the copied local .env.
#
# Current langchain-gigachat versions can read GIGACHAT_* variables through
# the underlying gigachat SDK. Use either OAuth credentials or user/password.

# Preferred OAuth-style auth:
GIGACHAT_CREDENTIALS=
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Alternative auth used by some local/internal installations:
GIGACHAT_USER=
GIGACHAT_PASSWORD=

# Optional runtime settings:
GIGACHAT_BASE_URL=
GIGACHAT_MODEL=
GIGACHAT_VERIFY_SSL_CERTS=true
GIGACHAT_PROFANITY_CHECK=false
